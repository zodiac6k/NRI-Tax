# Copy this file to .streamlit/secrets.toml (local) and NEVER commit the real one.
# On Streamlit Community Cloud, paste these into: App settings -> Secrets.
#
# Generate a Gmail App Password (requires 2FA enabled on the sender account):
# https://myaccount.google.com/apppasswords

gmail_sender = "your-sending-account@gmail.com"
gmail_app_password = "xxxx xxxx xxxx xxxx"
